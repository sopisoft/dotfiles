#!/usr/bin/env bash
set -euo pipefail

export NVM_DIR="${NVM_DIR:-$HOME/.local/share/nvm}"

resolve_default_node_version() {
    local alias_name alias_file alias_value
    alias_name="default"

    while true; do
        alias_file="${NVM_DIR}/alias/${alias_name}"
        [[ -f "${alias_file}" ]] || return 1

        alias_value="$(tr -d '[:space:]' < "${alias_file}")"
        [[ -n "${alias_value}" ]] || return 1

        if [[ "${alias_value}" == v* ]]; then
            printf '%s\n' "${alias_value}"
            return 0
        fi

        alias_name="${alias_value}"
    done
}

tool_name="$(basename "$0")"
node_version="$(resolve_default_node_version)" || {
    echo "No default Node.js version is installed in nvm." >&2
    exit 1
}

exec "${NVM_DIR}/versions/node/${node_version}/bin/${tool_name}" "$@"
